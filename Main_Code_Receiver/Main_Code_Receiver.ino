// ------------------ MENU PHASE ------------------
void drawMenu() {
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(WHITE);
  display.setCursor(37, 5);
  display.print("MAIN MENU");
  for (int i = 0; i < menuItemsCount; i++) {
    display.setCursor(5, 20 + i * 15);
    display.print(menuItems[i]);

    if (i == selectedItem) {
      display.setCursor(100, 20 + i * 15);
      display.print("<--");
    }
  }

  display.display();
}

void drawConfig(){
   display.clearDisplay();
   display.setTextSize(1);
   display.setTextColor(WHITE);
    display.setCursor(44, 5);
    display.print("CONFIG");
  for (int i = 0; i < configItemsCount; i++) {
    display.setCursor(5, 20 + i * 15);
    display.print(configItems[i]);

    if (i == configItem) {
      display.setCursor(100, 20 + i * 15);
      display.print("<--");
    }
  }

  display.display();
}

// ------------------ SETUP ------------------
void setup() {
  pinMode(buttonPinSelect, INPUT_PULLUP);
  pinMode(buttonPinPush, INPUT_PULLUP);
  pinMode(buttonPinBack, INPUT_PULLUP);

  Serial2.begin(9600, SERIAL_8N1, 4, 5); // HC-12 on pins 16 (RX) and 17 (TX)

  myservo.attach(SERVO_PIN, SERVO_MIN_US, SERVO_MAX_US); 
  pinMode(LED_PIN, OUTPUT);
  digitalWrite(LED_PIN, LOW);  // LED OFF initially

  

  if (!display.begin(SSD1306_SWITCHCAPVCC, SCREEN_ADDRESS)) {
    Serial.println(F("SSD1306 allocation failed"));
    for (;;);
  }
  neogps.begin(115200, SERIAL_8N1, RXD2, TXD2);
  // Show welcome screen
  display_welcome();
  delay(2000);

  // Finally show menu
  drawMenu();
}


// ------------------ LOOP ------------------
void loop() {
  if (Serial2.available()) {
    String line = Serial2.readStringUntil('\n');   // ex: "123,456,789,12,34,999"

    lastPacketTime = millis();
    // Split values
    int v[6];
    int index = 0;
    char *token;
    char buf[64];
    line.toCharArray(buf, 64);

    token = strtok(buf, ",");
    while (token != NULL && index < 6) {
      v[index++] = atoi(token);
      token = strtok(NULL, ",");
    }

    if (index == 6) {
      value5 = v[5];  // Use the 6th value from the PIC

      // Convert ADC reading (0–1023) into angle (0–180°)
      int angle = map(value5, 0, 1023, 180, 0);

     myservo.write(angle);

      Serial.printf("value5=%d  ->  angle=%d\n", value5, angle);
    }

  }
  if (millis() - lastPacketTime < timeout) {
    digitalWrite(LED_PIN, HIGH); //Connected
  }
  else { 
    digitalWrite(LED_PIN, LOW);  //Lost connection
  }
  
  //for (unsigned long start = millis(); millis() - start < 1000;)  /// to delete
  //{
    while (neogps.available())
    {
      if (gps.encode(neogps.read()))
      {
        newData = true;
      }
    }
  //}
  
  
  int buttonStateSelect = digitalRead(buttonPinSelect);  // scroll
  int buttonStatePush   = digitalRead(buttonPinPush);    // enter
  int buttonStateBack   = digitalRead(buttonPinBack);    // back

  if (millis() - lastDebounceTime < debounceDelay) return;
  if (configMenuState == STATE_LIVE_VIEW) display_live_view();

  // ---------------- MAIN MENU ----------------
  if (configMenuState == STATE_MAIN_MENU) {
    if (buttonStateSelect == LOW) {
      lastDebounceTime = millis();
      selectedItem++;
      if (selectedItem >= menuItemsCount) selectedItem = 0;
      drawMenu();
    }

    if (buttonStatePush == LOW) {
      lastDebounceTime = millis();
      if (selectedItem == 0) {
        configMenuState = STATE_LIVE_VIEW;   // go to LIVE VIEW
        display_live_view(); // example
        
      } 
      else if (selectedItem == 1) {
        configMenuState = STATE_CONFIG_MENU; // enter CONFIG
        configItem = 0;
        drawConfig();
      } 
      else if (selectedItem == 2) {
        configMenuState = STATE_BL_LINK;   // go to BL view
        display_BL();
      }
    }

    // BACK does nothing in main menu
  }

  // ---------------- CONFIG MENU ----------------
  else if (configMenuState == STATE_CONFIG_MENU) {
    if (buttonStateSelect == LOW) {
      lastDebounceTime = millis();
      configItem++;
      if (configItem >= configItemsCount) configItem = 0;
      drawConfig();
    }

    if (buttonStatePush == LOW) {
      lastDebounceTime = millis();
      if (configItem == 0) {
        configMenuState = STATE_CONFIG_SERVO;
        display.clearDisplay();
        display.setCursor(5, 30);
        display.print("SET SERVO...");
        display.display();
      }
      else if (configItem == 1) {
        configMenuState = STATE_CONFIG_THROTTLE;
        display.clearDisplay();
        display.setCursor(5, 30);
        display.print("SET THROTTLE...");
        display.display();
      }
      else if (configItem == 2) {
        configMenuState = STATE_CONFIG_LIVEVIEW;
        display.clearDisplay();
        display.setCursor(5, 30);
        display.print("LIVEVIEW OPT...");
        display.display();
      }
    }

    if (buttonStateBack == LOW) {
      lastDebounceTime = millis();
      configMenuState = STATE_MAIN_MENU;   // back to main menu
      drawMenu();
    }
  }

  // ---------------- CONFIG SUBMENUS ----------------
  else if (configMenuState == STATE_CONFIG_SERVO) {
    if (buttonStateBack == LOW) {
      lastDebounceTime = millis();
      configMenuState = STATE_CONFIG_MENU; // back to CONFIG menu
      drawConfig();
    }
  }

  else if (configMenuState == STATE_CONFIG_THROTTLE) {
    if (buttonStateBack == LOW) {
      lastDebounceTime = millis();
      configMenuState = STATE_CONFIG_MENU;
      drawConfig();
    }
  }

  else if (configMenuState == STATE_CONFIG_LIVEVIEW) {
    if (buttonStateBack == LOW) {
      lastDebounceTime = millis();
      configMenuState = STATE_CONFIG_MENU;
      drawConfig();
    }
  }

  // ---------------- BL VIEW ----------------
  else if (configMenuState == STATE_BL_LINK) {
    if (buttonStateBack == LOW) {
      lastDebounceTime = millis();
      configMenuState = STATE_MAIN_MENU;   // back to main menu
      drawMenu();
    }
  }

  else if (configMenuState == STATE_LIVE_VIEW) {
    if (buttonStateBack == LOW) {
      lastDebounceTime = millis();
      configMenuState = STATE_MAIN_MENU; // back to CONFIG menu
      drawMenu();
    }
  }
}
