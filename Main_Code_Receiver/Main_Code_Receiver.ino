float getTemperature()
{ 
 Wire.requestFrom(TMP102_ADDRESS,2); 
 byte MSB = Wire.read();
 byte LSB = Wire.read();
 //it's a 12bit int, using two's compliment for negative
 int TemperatureSum = (MSB << 4) + (LSB >> 4); // ((MSB << 8)| LSB) >> 4)
 float celsius;
 if(TemperatureSum & 0b100000000000)
 { 
 TemperatureSum = ~ TemperatureSum; 
 TemperatureSum += 1;
 TemperatureSum = TemperatureSum & 0b111111111111;
 celsius = TemperatureSum * -0.0625;
 } 
 else
 celsius = TemperatureSum*0.0625;
 return celsius; 
} 

void display_welcome() {
  display.clearDisplay();
  display.setTextSize(2);
  display.setTextColor(WHITE);

  display.drawBitmap(0, 0, car_bitmap, 128, 64, WHITE);

  display.display();
}

void display_live_view(){
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(WHITE);

  display.setCursor(40, 5);
  display.print("LIVEVIEW");

  display.setCursor(5, 18);
    display.print("Speed:");
    if(newData == true)
    {
      display.print(gps.speed.kmph());
      display.print(" Kph");
      display.setCursor(95, 5);
      display.print("S:");
      display.setCursor(110, 5);
      display.print(gps.satellites.value());
    }
    else display.print("NO GPS");
    display.setCursor(5, 33);
    display.print("Temp:");
    display.print(getTemperature(),2);
    display.print(" C");

    display.setCursor(5, 48);
    display.print("Current:0.00");
    display.print(" A");

  display.display();
 
}

